<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_purchase_ai" model="ir.ui.view">
        <field name="name">res.config.settings.view.purchase.ai</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='other']" position="before">
                <div id="kesiyos_ai" class="o_setting_box col-12">
                    <h2>Kesiyos AI — Escáner de Facturas</h2>
                    <div class="row mt16 o_settings_container">

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="kesiyos_claude_api_key" string="Claude API Key"/>
                                <div class="text-muted">
                                    Obtén tu key en console.anthropic.com (empieza con sk-ant-)
                                </div>
                                <div class="mt8">
                                    <field name="kesiyos_claude_api_key"
                                           password="True"
                                           placeholder="sk-ant-api03-..."/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="kesiyos_ai_model" string="Modelo Claude"/>
                                <div class="text-muted">
                                    Sonnet es el balance ideal entre velocidad y precisión.
                                </div>
                                <div class="mt8">
                                    <field name="kesiyos_ai_model"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="kesiyos_default_tax_id" string="Impuesto de Compra (IVA)"/>
                                <div class="text-muted">
                                    Impuesto aplicado por defecto a las líneas (ej. IVA 12%).
                                </div>
                                <div class="mt8">
                                    <field name="kesiyos_default_tax_id"
                                           domain="[('type_tax_use','=','purchase')]"/>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>